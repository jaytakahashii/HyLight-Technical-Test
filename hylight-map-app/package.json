{
  "name": "hylight-map-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky ../.husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "exifr": "7.1.3",
    "mapbox-gl": "3.25.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "8.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/mapbox-gl": "3.4.1",
    "@types/node": "24.13.1",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "eslint": "9.7.0",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "supabase": "2.107.0",
    "tailwindcss": "4.3.1",
    "typescript": "5.4.5"
  }
}
